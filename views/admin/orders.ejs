<!-- Vanilla JS Tab & Status Handler -->
<script>
    function filterOrders(category, tabBtn) {
        // Toggle tab highlights
        document.querySelectorAll('.admin-orders-tab').forEach(tab => {
            tab.classList.remove('active');
        });
        tabBtn.classList.add('active');
        
        // Show/hide cards
        document.querySelectorAll('.admin-order-card').forEach(card => {
            const status = card.getAttribute('data-status');
            if (category === 'all') {
                card.style.display = 'flex';
            } else if (category === 'pending' && status === 'pending') {
                card.style.display = 'flex';
            } else if (category === 'completed' && status === 'completed') {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function updateStatus(tokenId, statusType, btnElement) {
        // Find the parent actions container and deselect other active buttons
        const actionContainer = btnElement.closest('.admin-order-actions');
        actionContainer.querySelectorAll('.action-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        
        // Mark clicked button active
        btnElement.classList.add('active');
        
        // Update badge
        const badge = document.getElementById(`status-${tokenId}`);
        badge.className = `status-pill ${statusType}`;
        
        // Capitalize status string for text content
        const statusText = statusType.charAt(0).toUpperCase() + statusType.slice(1);
        badge.innerText = statusText;
        
        // Update parent card category for filter filtering
        const card = btnElement.closest('.admin-order-card');
        if (statusType === 'delivered') {
            card.setAttribute('data-status', 'completed');
        } else {
            card.setAttribute('data-status', 'pending');
        }
    }
</script>

