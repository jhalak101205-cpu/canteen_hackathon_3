<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="student-layout">
    <div class="container">
        <h2 style="margin-bottom: 24px;">Checkout Payment</h2>

        <div class="payment-grid">
            <!-- Left Side: Select Payment Method -->
            <div>
                <h3 style="font-size: 18px; margin-bottom: 16px;">Choose Payment Method</h3>

                <form id="paymentForm">
                    <input type="hidden" name="selectedMethod" id="selectedMethodInput" value="UPI">
                    <input type="hidden" name="finalAmount" id="finalAmountInput" value="180">

                    <div class="payment-options">
                        <!-- UPI -->
                        <div class="payment-option-card selected" onclick="selectPaymentMethod('UPI', this)">
                            <div class="payment-option-icon">📱</div>
                            <div class="payment-option-details">
                                <span class="payment-option-title">UPI (GPay / PhonePe / Paytm)</span>
                                <span class="payment-option-desc">Scan QR code and enter transaction ID</span>
                            </div>
                            <input type="radio" class="payment-option-radio" name="pay_radio" checked style="margin-left: auto;">
                        </div>

                        <!-- Pay Later -->
                        <div class="payment-option-card" onclick="selectPaymentMethod('PAY_LATER', this)">
                            <div class="payment-option-icon">🕒</div>
                            <div class="payment-option-details">
                                <span class="payment-option-title">Pay Later</span>
                                <span class="payment-option-desc">Order now and pay within 7 days</span>
                            </div>
                            <input type="radio" class="payment-option-radio" name="pay_radio" style="margin-left: auto;">
                        </div>

                        <!-- Pay at Counter -->
                        <div class="payment-option-card" onclick="selectPaymentMethod('PAY_AT_COUNTER', this)">
                            <div class="payment-option-icon">💵</div>
                            <div class="payment-option-details">
                                <span class="payment-option-title">Pay at Counter</span>
                                <span class="payment-option-desc">Order now and pay at canteen counter</span>
                            </div>
                            <input type="radio" class="payment-option-radio" name="pay_radio" style="margin-left: auto;">
                        </div>
                    </div>

                    <!-- UPI QR Box -->
                    <div id="upiQrBox" style="display: block; margin-top: 24px; padding: 20px; border: 1.5px dashed var(--primary); border-radius: 18px; background: #fff;">
                        <h3 style="margin-bottom: 12px;">Scan & Pay via UPI</h3>

                        <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                            <div style="width: 180px; height: 180px; border: 1px solid var(--border-color); border-radius: 14px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: white;">
                                <img 
                                    src="/images/canteen-qr.png" 
                                    alt="Canteen UPI QR Code" 
                                    style="width: 100%; height: 100%; object-fit: contain;"
                                    onerror="this.style.display='none'; this.parentElement.innerHTML='QR<br>Image<br>Missing';"
                                >
                            </div>

                            <div>
                                <p style="margin-bottom: 8px; color: var(--text-muted);">
                                    Scan this QR using GPay, PhonePe, Paytm, or any UPI app.
                                </p>

                                <label style="display: block; font-weight: 700; margin-bottom: 8px;">
                                    Enter UPI Transaction ID after payment
                                </label>

                                <input
                                    type="text"
                                    id="upiTransactionId"
                                    placeholder="Example: UPI123456789"
                                    style="padding: 12px 14px; border-radius: 10px; border: 1px solid var(--border-color); width: 260px;"
                                >
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="checkout-btn" style="margin-top: 30px;">
                        I Have Paid <span id="payButtonAmount">₹180</span> ✅
                    </button>
                </form>
            </div>

            <!-- Right Side: Order Summary -->
            <div class="bill-summary-card" style="height: fit-content;">
                <h3 style="margin-bottom: 20px; font-size: 18px; border-bottom: 1.5px solid var(--border-color); padding-bottom: 12px;">
                    Order Summary
                </h3>

                <div id="paymentSummaryContainer" style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px;">
                    <!-- Items will be loaded from localStorage -->
                </div>

                <div class="bill-row">
                    <span>Subtotal</span>
                    <span id="sumSubtotal">₹160</span>
                </div>

                <div class="bill-row">
                    <span>Packing & Taxes</span>
                    <span id="sumFees">₹20</span>
                </div>

                <div class="bill-row total">
                    <span>Amount Payable</span>
                    <span id="sumTotal">₹180</span>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    function selectPaymentMethod(method, element) {
        document.querySelectorAll(".payment-option-card").forEach(card => {
            card.classList.remove("selected");
            card.querySelector(".payment-option-radio").checked = false;
        });

        element.classList.add("selected");
        element.querySelector(".payment-option-radio").checked = true;

        document.getElementById("selectedMethodInput").value = method;

        const amount = document.getElementById("finalAmountInput").value;
        const button = document.querySelector(".checkout-btn");
        const upiQrBox = document.getElementById("upiQrBox");

        if (method === "UPI") {
            upiQrBox.style.display = "block";
            button.innerHTML = `I Have Paid <span id="payButtonAmount">₹${amount}</span> ✅`;
        } else if (method === "PAY_LATER") {
            upiQrBox.style.display = "none";
            button.innerHTML = `Place Order - Pay Later <span id="payButtonAmount">₹${amount}</span> 🕒`;
        } else if (method === "PAY_AT_COUNTER") {
            upiQrBox.style.display = "none";
            button.innerHTML = `Place Order <span id="payButtonAmount">₹${amount}</span> 🍽️`;
        }
    }

    function loadOrderDetails() {
        const cart = JSON.parse(localStorage.getItem("canteen_cart") || "[]");
        const total = Number(localStorage.getItem("canteen_last_total") || 180);

        document.getElementById("sumTotal").innerText = `₹${total}`;
        document.getElementById("payButtonAmount").innerText = `₹${total}`;
        document.getElementById("finalAmountInput").value = total;

        const subtotalValue = Math.max(0, total - 20);
        const fees = total - subtotalValue;

        document.getElementById("sumSubtotal").innerText = `₹${subtotalValue}`;
        document.getElementById("sumFees").innerText = `₹${fees}`;

        const container = document.getElementById("paymentSummaryContainer");

        if (cart.length > 0) {
            container.innerHTML = cart.map(item => {
                const quantity = Number(item.qty || item.quantity || 1);
                const price = Number(item.price || 0);

                return `
                    <div style="display: flex; justify-content: space-between; font-size: 14px;">
                        <span style="color: var(--text-muted);">
                            <strong style="color: var(--primary);">${quantity}x</strong> ${item.name}
                        </span>
                        <span style="font-weight: 600; color: var(--primary-dark);">
                            ₹${price * quantity}
                        </span>
                    </div>
                `;
            }).join("");
        } else {
            container.innerHTML = `
                <div style="display: flex; justify-content: space-between; font-size: 14px;">
                    <span style="color: var(--text-muted);">
                        No items found in cart
                    </span>
                    <span style="font-weight: 600; color: var(--primary-dark);">₹0</span>
                </div>
            `;
        }
    }

    document.getElementById("paymentForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const cart = JSON.parse(localStorage.getItem("canteen_cart") || "[]");
        const selectedMethod = document.getElementById("selectedMethodInput").value;
        const totalAmount = Number(document.getElementById("finalAmountInput").value);

        if (cart.length === 0) {
            alert("Your cart is empty. Please add items before placing an order.");
            window.location.href = "/student/menu";
            return;
        }

        let upiTransactionId = null;

        if (selectedMethod === "UPI") {
            upiTransactionId = document.getElementById("upiTransactionId").value.trim();

            if (!upiTransactionId) {
                alert("Please scan the QR and enter your UPI transaction ID.");
                return;
            }
        }

        const finalItems = cart.map(item => {
            return {
                itemId: item.itemId || undefined,
                name: item.name,
                price: Number(item.price),
                image: item.image || "🍽️",
                quantity: Number(item.qty || item.quantity || 1)
            };
        });

        const orderData = {
            studentName: "Test Student",
            studentEmail: "student@test.com",
            studentPhone: "9876543210",
            collegeName: "Mirai School of Technology",
            items: finalItems,
            totalAmount: totalAmount,
            paymentMethod: selectedMethod,
            upiTransactionId: upiTransactionId
        };

        try {
            const response = await fetch("/api/payment/create-order", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(orderData)
            });

            const result = await response.json();

            if (result.success) {
                localStorage.removeItem("canteen_cart");
                localStorage.removeItem("canteen_last_total");

                alert("Order placed successfully!");
                window.location.href = "/student/success";
            } else {
                alert(result.message || "Something went wrong while placing order");
            }
        } catch (error) {
            console.error("Payment error:", error);
            alert("Failed to place order. Please check server.");
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        loadOrderDetails();
        selectPaymentMethod("UPI", document.querySelector(".payment-option-card.selected"));
    });
</script>

<%- include("../partials/footer") %>