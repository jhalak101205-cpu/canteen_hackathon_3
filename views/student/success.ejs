<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="student-layout">
    <div class="container" style="display: flex; align-items: center; justify-content: center; min-height: calc(100vh - var(--header-height) - 150px);">
        <div class="success-card">
            <div class="success-icon-container">
                <div class="success-checkmark">✓</div>
            </div>
            
            <h1 style="font-size: 28px; margin-bottom: 12px; font-weight: 800;">Order Placed Successfully!</h1>
            <p style="color: var(--text-muted); font-size: 15px; max-width: 400px; margin: 0 auto;">
                Your request has been received by the canteen staff. Please present your token at the counter or wait at your table.
            </p>
            
            <!-- Token Box -->
            <div class="success-token-badge">
                <div class="success-token-label">Your Digital Token</div>
                <!-- Token number placeholder -->
                <div class="success-token-number" id="tokenPlaceholder">T-742</div>
            </div>
            
            <!-- Details & Status Tracker -->
            <div class="success-details">
                <div class="success-detail-row">
                    <span>Order Status</span>
                    <!-- Order status placeholder -->
                    <span style="font-weight: 700; color: var(--secondary);" id="statusPlaceholder">Preparing</span>
                </div>
                <div class="success-detail-row">
                    <span>Estimated Time</span>
                    <span style="font-weight: 600;" id="timerPlaceholder">8-10 Mins</span>
                </div>
                <div class="success-detail-row">
                    <span>Delivery Mode</span>
                    <span style="font-weight: 600;">Table 4</span>
                </div>
            </div>
            
            <!-- Backend route will be added here -->
            <a href="" class="success-btn">
                🍽️ Back to Menu
            </a>
        </div>
    </div>
</main>

<!-- Vanilla JS Success Simulation -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Generate a random token number on page load
        const randomToken = 'T-' + Math.floor(1000 + Math.random() * 9000);
        document.getElementById('tokenPlaceholder').innerText = randomToken;
        
        // Simple status simulation
        const statusEl = document.getElementById('statusPlaceholder');
        const timerEl = document.getElementById('timerPlaceholder');
        
        // Mock timeline transitions
        setTimeout(() => {
            statusEl.innerText = "Food Ready! 😋";
            statusEl.style.color = "var(--accent)";
            timerEl.innerText = "Now at the Counter";
        }, 8000);
    });
</script>

<%- include("../partials/footer") %>
